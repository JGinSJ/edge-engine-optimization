# Harper Cache Pipeline — configuration reference
#
# The EdgeWorker reads PMUSER_* values from Akamai property variables at runtime.
# No secrets appear in the bundle or in git.
#
# Copy to .env for local tooling (cache-warm script). .env is excluded from git.

# ── Akamai property variables (set in Control Center, not here) ──────────
# PMUSER_HARPER_ENABLED            true
# PMUSER_HARPER_URL                /_harper            ← RELATIVE proxy path for EW READS
#                                  (on-property "Harper Proxy" rule rewrites /_harper/ → / to the Harper origin)
# PMUSER_HARPER_WRITE_URL          https://ai-seo-pipeline.jgeronim-org.harperfabric.com
#                                  ← ABSOLUTE URL the EW forwards to Fermyon for the write-back
#                                  (Fermyon is off-property and can't use the relative proxy path)
# PMUSER_HARPER_TOKEN              <bearer-token>                  ← mark Sensitive
# PMUSER_HARPER_TIMEOUT_MS         1500
# PMUSER_WASM_URL                  https://977adc68-2ede-4bf3-9b1e-41923fa6d7a9.fwf.app   ← isolated converter (write-back enabled)

# ── Local tooling (cache-warm script) ────────────────────────────────────
HARPER_URL=https://ai-seo-pipeline.jgeronim-org.harperfabric.com
HARPER_TOKEN=<your-bearer-token>
WASM_URL=https://bede2402-c4b7-4234-b17c-5e04fc46ef00.fwf.app
