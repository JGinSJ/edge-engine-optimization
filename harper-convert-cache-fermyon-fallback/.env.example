# Harper Markdown Prerender — configuration reference
#
# The EdgeWorker reads HARPER_* values from Akamai property variables at runtime
# (Control Center → Property Manager → Property Variables). No secrets appear
# in the bundle or in git.
#
# Copy this file to .env for local tooling (bulk-upload script, mock server).
# .env is excluded from git.

# ── Akamai property variables (set in Control Center, not here) ───────────────
# PMUSER_HARPER_ENABLED   true
# PMUSER_HARPER_URL       https://your-harper-app-url/_harper
# PMUSER_HARPER_TOKEN     your-harper-jwt-token          ← mark Sensitive
# PMUSER_HARPER_TIMEOUT_MS 1500

# ── Local tooling only (bulk-upload script and mock server) ───────────────────
HARPER_ENABLED=false
HARPER_OPS_URL=https://gq4-your-node.harperfabric.com  # node URL (port 443) — /bulk_upload/
HARPER_ADMIN_USER=your-harper-admin-user               # HarperDB admin username (Basic auth)
HARPER_ADMIN_PASS=your-harper-admin-password           # HarperDB admin password
HARPER_TIMEOUT_MS=1500
